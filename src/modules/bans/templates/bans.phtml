    <script>
      function toggle_ban_preview(el) {
        var trigger = el.parentElement;
        var popup = trigger.querySelector('.ban-preview-popup');
        if (trigger.classList.toggle('active')) {
          var rect = el.getBoundingClientRect();
          popup.style.right = (document.documentElement.clientWidth - rect.left) + 'px';
          popup.style.top = (rect.bottom + 2) + 'px';
        }
      }
      document.addEventListener('click', function(e) {
        if (e.target.closest('.ban-preview-trigger')) return;
        document.querySelectorAll('.ban-preview-trigger.active').forEach(function(el) {
          el.classList.remove('active');
        });
      });
    </script>
