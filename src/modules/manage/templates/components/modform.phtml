          $preview = '';
          if ($post['parent_id'] == 0) {
            $preview = $this->render(__DIR__ . '/post_preview_op.phtml', ['post' => $post]);
          } else {
            $preview = $this->render(__DIR__ . '/post_preview_reply.phtml', ['post' => $post]);
          }

          $deleted = $post['deleted'] === 1 ? '<b>TRUE</b>' : 'FALSE';
          $imported = $post['imported'] === 1 ? '<b>TRUE</b>' : 'FALSE';
          echo "
            <tr>
              <td><input type=\"checkbox\" name=\"select[]\" value=\"{$post['board_id']}/{$post['post_id']}\"></td>
              <td>{$post['id']}</td>
              <td>{$post['post_id']}</td>
